# Environment variables for infrastructure services

# PostgreSQL
POSTGRES_USER=medagent
POSTGRES_PASSWORD=medagent_dev_password
POSTGRES_DB=medagent
POSTGRES_PORT=5432
POSTGRES_HOST=localhost

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin_password
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ENDPOINT=http://localhost:9000

# Database URL for application
MEDAGENT_DATABASE_URL=postgresql://medagent:medagent_dev_password@localhost:5432/medagent

# MinIO URL for application
MEDAGENT_MINIO_ENDPOINT=http://localhost:9000
MEDAGENT_MINIO_ACCESS_KEY=minioadmin
MEDAGENT_MINIO_SECRET_KEY=minioadmin_password
MEDAGENT_MINIO_BUCKET=uploads

# API Keys (fill in your own)
DASHSCOPE_API_KEY=your_dashscope_api_key_here
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Model Configuration
QWEN_REASONING_MODEL=qwen-max
QWEN_TASK_MODEL=qwen-plus
DEEPSEEK_REFUTATION_MODEL=deepseek-chat
EMBEDDING_MODEL=text-embedding-v3

# Application
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO
