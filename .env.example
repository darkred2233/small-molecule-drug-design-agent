MEDAGENT_APP_NAME="Small Molecule Drug Design Agent"
MEDAGENT_DATABASE_URL="postgresql+psycopg://medagent:medagent@localhost:5432/medagent"
MEDAGENT_STORAGE_ENDPOINT="localhost:9000"
MEDAGENT_STORAGE_ACCESS_KEY="medagent"
MEDAGENT_STORAGE_SECRET_KEY="medagent-secret"
MEDAGENT_STORAGE_BUCKET="medagent-files"
MEDAGENT_QWEN_REASONING_MODEL="qwen3.7-max"
MEDAGENT_QWEN_TASK_MODEL="qwen3.7-plus"
MEDAGENT_DEEPSEEK_REFUTATION_MODEL="deepseek-v4-pro"
MEDAGENT_EMBEDDING_MODEL="text-embedding-v4"
MEDAGENT_RERANK_MODEL="qwen3-rerank"
MEDAGENT_RAG_EMBEDDING_DIMENSION=2048
MEDAGENT_RAG_CHUNK_SIZE=1800
MEDAGENT_RAG_CHUNK_OVERLAP=180
MEDAGENT_RAG_VECTOR_TOP_K=80
MEDAGENT_RAG_KEYWORD_TOP_K=80
MEDAGENT_RAG_DEFAULT_TOP_K=10
MEDAGENT_RAG_USE_REMOTE_EMBEDDINGS=true
MEDAGENT_RAG_USE_REMOTE_RERANK=true
# Optional. When unset, RAG uses deterministic local hash/BM25 retrieval without
# fabricating reranker scores or calibrated evidence confidence.
MEDAGENT_DASHSCOPE_API_KEY=""
MEDAGENT_DASHSCOPE_COMPATIBLE_BASE_URL="https://dashscope.aliyuncs.com/compatible-mode/v1"
# qwen3-rerank is workspace-routed in DashScope; set this only after creating/enabling the rerank endpoint.
MEDAGENT_DASHSCOPE_RERANK_URL=""

# Local model files used by the chemistry adapters.
REINVENT4_PRIOR_FILE="./.local/models/reinvent4/reinvent_pubchem.prior"
DIFFDOCK_MODEL_DIR="./.local/models/diffdock/score_model"
DIFFDOCK_CONFIDENCE_MODEL_DIR="./.local/models/diffdock/confidence_model"
MEDAGENT_DOCKER_WORK_ROOT="./.local/tool-runs"
MEDAGENT_TOOLS_CONFIG="./configs/tools.yaml"
GNINA_IMAGE="gnina/gnina:latest"
DIFFDOCK_IMAGE="diffdock:latest"
REINVENT4_IMAGE="reinvent4:latest"
AUTOGROW4_IMAGE="autogrow4:latest"
DIFFDOCK_TIMEOUT_SECONDS=900
REINVENT4_TIMEOUT_SECONDS=600
AUTOGROW4_TIMEOUT_SECONDS=1200
AUTOGROW4_REF="1b47b3fe2d9faa76a904533bea2312326a3f44c5"
AIZYNTHFINDER_CONFIG="./data/aizynthfinder/config.yml"
MEDAGENT_AIZYNTHFINDER_DATA_DIR="./data/aizynthfinder"
